[Unit]
Description=Backup Nheenga PostgreSQL
After=postgresql.service
Wants=postgresql.service

[Service]
Type=oneshot
User=deploy
Group=deploy
WorkingDirectory=/srv/nheenga-neologismos
Environment=API_ENV_FILE=/srv/nheenga-neologismos/apps/api/.env.production
ExecStart=/srv/nheenga-neologismos/scripts/backup-postgres.sh
